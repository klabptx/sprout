# ---------------------------------------------------------------------------
# Sprout pipeline — environment variable reference
# Copy to .env and fill in values for your environment.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Tailor stream API (required — choose one form)
# ---------------------------------------------------------------------------
# Option A: full URL
TAILOR_STREAM_URL=

# Option B: composed from components (used if TAILOR_STREAM_URL is not set)
TAILOR_BASE_URL=
TAILOR_ORG_CODE=
TAILOR_STREAM_ID=

# ---------------------------------------------------------------------------
# Stitch file-system API
# ---------------------------------------------------------------------------
STITCH_LOCAL_BASE_URL=http://localhost:8888

# ---------------------------------------------------------------------------
# Anomaly detection
# ---------------------------------------------------------------------------
# Minimum percentage deviation to flag an anomaly (0–1, default 0.25)
COMPARE_PCT_THRESHOLD=0.25
# Minimum absolute value deviation (default 0.0 = no abs gate)
COMPARE_ABS_THRESHOLD=0.0
# Maximum events to process per run (default 200)
COMPARE_MAX_EVENTS=200

# ---------------------------------------------------------------------------
# Pipeline defaults
# ---------------------------------------------------------------------------
# LLM backend: auto | openai | local | vllm | lambda (default openai)
LLM_BACKEND=openai
# Severity threshold for routing augment vs. synthesize (default 0.75)
SEVERITY_THRESHOLD=0.75
# Comma-separated event codes or ranges to exclude (e.g. 403,12000-13000)
EXCLUDE_EVENT_CODES=
# Path to SystemLog.proto for event code metadata
EVENT_PROTO_PATH=SystemLog.proto
# Hardware sensor sample rate (used in Run node metadata)
SAMPLE_RATE_HZ=5

# ---------------------------------------------------------------------------
# Confidence scoring (overrides built-in defaults)
# ---------------------------------------------------------------------------
CONFIDENCE_BASE_GOOD=0.78
CONFIDENCE_BASE_POOR=0.62
CONFIDENCE_SEVERITY_PENALTY=0.06

# ---------------------------------------------------------------------------
# LLM — OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# ---------------------------------------------------------------------------
# LLM — Local HuggingFace / PEFT (optional — requires [local] extras)
# ---------------------------------------------------------------------------
# Set either LOCAL_MODEL_DIR (filesystem path) or LOCAL_MODEL_ID (HF Hub ID)
LOCAL_MODEL_DIR=
LOCAL_MODEL_ID=
# Required when using a PEFT adapter on top of a base model
LOCAL_ADAPTER_DIR=
LOCAL_BASE_MODEL=
LOCAL_MAX_NEW_TOKENS=256
LOCAL_TEMPERATURE=0.2

# ---------------------------------------------------------------------------
# LLM — vLLM remote server (optional)
# ---------------------------------------------------------------------------
VLLM_BASE_URL=
VLLM_MODEL=
VLLM_API_KEY=token-abc123

# ---------------------------------------------------------------------------
# LLM — Lambda.ai (optional)
# ---------------------------------------------------------------------------
LAMBDA_API_KEY=
LAMBDA_MODEL=lambda_ai/llama3.1-8b-instruct
